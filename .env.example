# Copia este archivo a ".env" y pon tu clave de API-Football (API-Sports).
# El archivo .env está en .gitignore: NUNCA se sube a Git.
# En producción (Vercel) esta variable se configura en:
#   Project Settings -> Environment Variables -> API_FOOTBALL_KEY
#
# Clave DIRECTA de https://dashboard.api-football.com (32 caracteres hex).
API_FOOTBALL_KEY=tu_clave_aqui
